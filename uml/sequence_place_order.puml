@startuml sequence_place_order
skinparam backgroundColor #0a0a0f
skinparam sequenceParticipantBackgroundColor #12121a
skinparam sequenceParticipantBorderColor #444466
skinparam sequenceArrowColor #00ff87
skinparam fontColor #e8e8f0
skinparam sequenceLifeLineBorderColor #444466

title Place Order — Sequence Diagram

actor Client
participant "index.html\n(Browser)" as HTML
participant "OrderServlet\n/api/orders" as Servlet
participant "OrderService\n(Facade)" as Service
participant "PaymentStrategy\n(Strategy)" as Payment
participant "MenuItemDAOImpl" as MenuDAO
participant "OrderDAOImpl" as OrderDAO
database "MySQL" as DB

Client -> HTML : Fill cart + seat number\nChoose payment method
Client -> HTML : Click "Place Order"
HTML -> Servlet : POST /api/orders\n{seatNumber, items, paymentMethod}
activate Servlet

Servlet -> Servlet : requireRole(CLIENT)
Servlet -> Service : placeOrder(clientId, seat, items, method)
activate Service

Service -> Service : resolveStrategy("ONLINE"|"CASH")
Service -> Payment : new OnlinePaymentStrategy\n(or CashPaymentStrategy)

loop for each cart item
  Service -> MenuDAO : findById(menuItemId)
  MenuDAO -> DB : SELECT * FROM menu_items WHERE id=?
  DB --> MenuDAO : ResultSet
  MenuDAO --> Service : Optional<MenuItem>
  Service -> Service : validate available, calc price
end

Service -> Payment : processPayment(totalAmount)
Payment --> Service : "ONLINE" (or "CASH")

Service -> OrderDAO : saveWithItems(order, orderItems)
activate OrderDAO
OrderDAO -> DB : BEGIN TRANSACTION
OrderDAO -> DB : INSERT INTO orders (...)
DB --> OrderDAO : generated orderId
OrderDAO -> DB : INSERT INTO order_items (batch)
OrderDAO -> DB : COMMIT
DB --> OrderDAO : OK
deactivate OrderDAO
OrderDAO --> Service : Order (with id)

deactivate Service
Service --> Servlet : Order

Servlet -> Servlet : writeJson(201, order)
Servlet --> HTML : HTTP 201 order JSON
HTML -> Client : Show "Order #N placed!" toast\nRedirect to My Orders
@enduml
