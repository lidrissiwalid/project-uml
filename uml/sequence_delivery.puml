@startuml sequence_delivery
skinparam backgroundColor #0a0a0f
skinparam sequenceParticipantBackgroundColor #12121a
skinparam sequenceParticipantBorderColor #444466
skinparam sequenceArrowColor #00ff87
skinparam fontColor #e8e8f0
skinparam sequenceLifeLineBorderColor #444466

title Worker Delivery Flow — Sequence Diagram

actor Worker
participant "index.html\n(Browser)" as HTML
participant "OrderServlet\n/api/orders" as Servlet
participant "OrderService\n(Facade)" as Service
participant "OrderDAOImpl" as OrderDAO
database "MySQL" as DB

== Worker Dashboard Load ==

Worker -> HTML : Navigate to Worker Dashboard
HTML -> Servlet : GET /api/orders
activate Servlet
Servlet -> Servlet : requireLogin()\ngetSessionRole() = WORKER
Servlet -> Service : getActiveOrders()
activate Service
Service -> OrderDAO : findByStatus("PENDING")
OrderDAO -> DB : SELECT ... WHERE status = 'PENDING'
DB --> OrderDAO : ResultSet
OrderDAO --> Service : List<Order>
Service -> OrderDAO : findByStatus("IN_DELIVERY")
OrderDAO -> DB : SELECT ... WHERE status = 'IN_DELIVERY'
DB --> OrderDAO : ResultSet
OrderDAO --> Service : List<Order>
Service --> Servlet : combined List<Order>
deactivate Service
Servlet --> HTML : HTTP 200 orders JSON
deactivate Servlet
HTML -> Worker : Display Pending / In-Delivery columns

== Accept Order ==

Worker -> HTML : Click "Accept & Deliver" on Order #N
HTML -> Servlet : PUT /api/orders/N/status\n{status: "IN_DELIVERY"}
activate Servlet
Servlet -> Servlet : requireRole(WORKER or ADMIN)
Servlet -> Service : updateStatus(N, "IN_DELIVERY")
activate Service
Service -> Service : validate status in allowed list
Service -> OrderDAO : findById(N)
OrderDAO -> DB : SELECT * FROM orders WHERE id=N
DB --> OrderDAO : Order
OrderDAO --> Service : Optional<Order>
Service -> OrderDAO : updateStatus(N, "IN_DELIVERY")
OrderDAO -> DB : UPDATE orders SET status='IN_DELIVERY' WHERE id=N
DB --> OrderDAO : 1 row updated
OrderDAO --> Service : void
Service --> Servlet : void
deactivate Service
Servlet --> HTML : HTTP 200 {message: "Order status updated"}
deactivate Servlet
HTML -> Worker : Toast "Order #N → IN DELIVERY"\nRefresh dashboard

== Mark Delivered ==

Worker -> HTML : Click "Mark Delivered" on Order #N
HTML -> Servlet : PUT /api/orders/N/status\n{status: "DELIVERED"}
activate Servlet
Servlet -> Service : updateStatus(N, "DELIVERED")
activate Service
Service -> OrderDAO : updateStatus(N, "DELIVERED")
OrderDAO -> DB : UPDATE orders SET status='DELIVERED' WHERE id=N
DB --> OrderDAO : OK
Service --> Servlet : void
deactivate Service
Servlet --> HTML : HTTP 200
deactivate Servlet
HTML -> Worker : Toast "Order #N → DELIVERED"
@enduml
